# 제주항공 AI NOTAM 분석 시스템 — 환경 변수

# =============================================================
# Amazon Bedrock 설정 (AI 기능 필수)
# AI 기능은 실제 Bedrock 호출이 필수입니다 (Mocking 금지)
# =============================================================

# AWS 리전 (Bedrock 모델 배포 리전)
AWS_REGION=us-east-1

# Bedrock 모델 ID (cross-region inference 지원)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# AWS 프로파일 (로컬 개발 시 권장)
# AWS_PROFILE=default

# AWS 자격 증명 (IAM Role 미사용 시)
# 주의: IAM Role 또는 AWS 프로파일 사용을 권장합니다
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# =============================================================
# 프로덕션 전환 시 추가 설정 (현재 미사용)
# =============================================================

# 데이터베이스 (인메모리 스토어 교체 시)
# DYNAMODB_TABLE_PREFIX=notam-prod
# DATABASE_URL=postgresql://user:pass@host:5432/notam

# 인증 (Mock 인증 교체 시)
# COGNITO_USER_POOL_ID=us-east-1_xxxxxxxx
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS 설정 (프로덕션 시 특정 도메인으로 제한)
# ALLOWED_ORIGINS=https://your-domain.com

# 로깅 레벨
# LOG_LEVEL=info

# 앱 설정
# NEXT_PUBLIC_APP_NAME=NOTAM 분석 시스템
# NODE_ENV=production
